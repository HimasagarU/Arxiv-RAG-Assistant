# ArXiv RAG Assistant - Environment Variables
# Copy this file to .env and fill in values

# --- LLM (Groq - free tier, get key at https://console.groq.com/keys) ---
GROQ_API_KEY=

# --- Paths ---
CHROMA_DIR=data/chroma_db
BM25_INDEX_PATH=data/bm25_index.pkl
DB_PATH=data/arxiv_papers.db
CHUNKS_PATH=data/chunks.jsonl

# --- Models ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=ms-marco-MiniLM-L-6-v2

# --- Local Full Retrieval Mode (force-enable all retrieval components) ---
ENABLE_BM25=true
ENABLE_RERANKER=true
RERANKER_LAZY_LOAD=true

# Optional memory guard thresholds (used only when ENABLE_* is unset)
BM25_MIN_MEMORY_MB=640
RERANKER_MIN_MEMORY_MB=768

# --- Retrieval Params ---
K_DENSE=50
K_LEX=50
MERGE_TOP_M=20
FINAL_TOP_N=5
ALPHA=0.7
BETA=0.3

# --- Ingestion ---
ARXIV_CATEGORIES=cs.AI,cs.LG
MAX_PAPERS=5000

# Full-text PDF extraction limits
PDF_TIMEOUT=30
MAX_FULLTEXT_CHARS=150000
MAX_FULLTEXT_PAPERS=0

# Chunk source mode: abstract | full_text | auto
CHUNK_SOURCE_MODE=auto

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
