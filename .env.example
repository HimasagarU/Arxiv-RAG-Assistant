# ArXiv RAG Assistant - Environment Variables
# Copy this file to .env and fill in values for the services you use.

# --- Backend databases ---
# Corpus/offline ingestion database: papers, chunks, citation_edges.
DATABASE_URL=postgresql://user:password@host:port/dbname
# Application database: users, conversations, messages, document_jobs.
APP_DATABASE_URL=postgresql://user:password@host:port/dbname

# --- Frontend ---
# Vercel/Vite backend URL, for example https://your-api.example.com
VITE_API_URL=http://localhost:8000

# --- Cache ---
# Optional. If unset, Redis cache operations are skipped.
REDIS_URL=
REDIS_MAX_CONNECTIONS=50

# --- Cloudflare R2 artifact/PDF storage ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=arxiv-rag-assist
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
ARTIFACT_ZIP_NAME=artifacts_v1.zip

# --- Local artifact paths ---
DATA_DIR=data
CHUNKS_PATH=data/chunks.jsonl

# --- Qdrant Cloud ---
QDRANT_URL=
QDRANT_API_KEY=

# --- Gemini (LLM) ---
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_TOP_P=0.9
GEMINI_RPM=5
GEMINI_RPD=0

# --- Groq fallback for Gemini rate limits (optional) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2
GROQ_MAX_OUTPUT_TOKENS=2048
GROQ_TOP_P=0.9

# --- Optional evaluation overrides ---
# RAGAS_JUDGE_MODEL overrides GEMINI_MODEL when running eval/ragas_eval.py
RAGAS_JUDGE_MODEL=
# RAGAS_RPM overrides GEMINI_RPM for eval runs
RAGAS_RPM=

# --- Models ---
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
ENABLE_RERANKER=true

# --- Retrieval ---
RRF_K=60
MAX_CHUNKS_PER_PAPER=2
K_DENSE=50
K_LEX=50
MERGE_TOP_M=30
FINAL_TOP_N=5
GENERATION_CONTEXT_TOP_N=20
RERANK_POOL_MULTIPLIER=8

# Parent–child (arxiv_docs → chunk expansion). Unset = auto (on if arxiv_docs exists in Qdrant).
# ENABLE_PARENT_CHILD=false | true | (unset=auto)
ENABLE_PARENT_CHILD=
PARENT_TOP_DOCS=12
PARENT_CHUNKS_PER_DOC=8

# Feature flags
# HyDE, query expansion, and context compression are now default-on for improved retrieval quality.
# They add ~1–3s latency and ~$0.002 Groq cost per query. Disable if you need strict cost control.
ENABLE_MMR=true
ENABLE_HYDE=false
ENABLE_QUERY_EXPANSION_LLM=true
ENABLE_QUERY_EXPANSION=false
ENABLE_CONTEXT_COMPRESSION=true
ENABLE_LLM_CONTEXT_COMPRESS=false
ENABLE_CITATION_BOOST=false
LEXICAL_LOAD_CHUNKS_TEXT=false

# --- Qdrant indexing/upsert tuning ---
QDRANT_EMBED_BATCH_SIZE=64
QDRANT_UPSERT_BATCH_SIZE=16
QDRANT_UPSERT_RETRIES=5
QDRANT_UPSERT_BACKOFF_SECONDS=2.0

# --- Corpus / ingestion ---
CORPUS_TARGET_MIN=500
CORPUS_TARGET_MAX=5000
ARXIV_REQUEST_TIMEOUT=60
PDF_TIMEOUT=60
PDF_DOWNLOAD_RETRIES=2
MAX_FULLTEXT_CHARS=200000
DB_WRITE_RETRIES=3
SEMANTIC_SCHOLAR_API_KEY=
CITATION_EXPANDER_STATE=data/citation_expander_state.json
KEYWORD_STATE_PATH=data/keyword_ingest_state.json

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# --- Auth ---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
