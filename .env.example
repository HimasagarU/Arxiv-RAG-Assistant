# ArXiv RAG Assistant - Environment Variables
# Copy this file to .env and fill in values

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arxiv_rag

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=arxiv-rag-assist
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# --- Qdrant Cloud ---
# Example: https://xxxxxxx.us-east-1-0.aws.cloud.qdrant.io
QDRANT_URL=
QDRANT_API_KEY=

# --- LLM (Groq - get key at https://console.groq.com/keys) ---
GROQ_API_KEY=

# --- Models ---
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-large

# --- Retrieval ---
RRF_K=60
MAX_CHUNKS_PER_PAPER=2
K_DENSE=50
K_LEX=50
MERGE_TOP_M=30
FINAL_TOP_N=5

# --- Qdrant Upsert Tuning ---
QDRANT_UPSERT_BATCH_SIZE=16
QDRANT_UPSERT_RETRIES=5
QDRANT_UPSERT_BACKOFF_SECONDS=2.0

# --- Corpus / Ingestion ---
CHUNKS_PATH=data/chunks.jsonl
CORPUS_TARGET_MIN=500
CORPUS_TARGET_MAX=5000
PDF_TIMEOUT=60
MAX_FULLTEXT_CHARS=200000
DB_WRITE_RETRIES=3

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000
